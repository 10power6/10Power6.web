# Copy to .env.local and fill values for production
# Vite will expose vars prefixed with VITE_
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
# Optional: override recipient if using a custom template that requires it
# VITE_EMAIL_RECIPIENT=sales.10power6@gmail.com
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
